# Copy to .env and adjust.
# Local Mongo via the included docker-compose (default). For Atlas, use your own
# connection string and URL-encode any special characters in the password
# (e.g. @ -> %40), otherwise the URI will not parse.
MONGODB_URI=mongodb+srv://gaurav_db_user:gaurav@123@cluster0.xe1nxbz.mongodb.net/?appName=Cluster0
# Example Atlas form:
# MONGODB_URI=mongodb+srv://<user>:<url-encoded-password>@<cluster>.mongodb.net/grn?appName=Cluster0
JWT_SECRET=please-change-me-to-a-long-random-string
PORT=5000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Where the browser app is served from in production (leave as-is for single-service deploy)
CLIENT_ORIGIN=*
